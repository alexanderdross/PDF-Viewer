{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 2,
    "settings": {
        "appearanceTools": true,
        "color": {
            "custom": true,
            "customDuotone": false,
            "customGradient": true,
            "defaultDuotone": false,
            "defaultGradients": false,
            "defaultPalette": false,
            "palette": [
                {
                    "color": "#1a5a8a",
                    "name": "Primary",
                    "slug": "primary"
                },
                {
                    "color": "#ffffff",
                    "name": "Primary Foreground",
                    "slug": "primary-foreground"
                },
                {
                    "color": "#c55a11",
                    "name": "Accent",
                    "slug": "accent"
                },
                {
                    "color": "#f0f2f5",
                    "name": "Background",
                    "slug": "background"
                },
                {
                    "color": "#1a1d24",
                    "name": "Foreground",
                    "slug": "foreground"
                },
                {
                    "color": "#ffffff",
                    "name": "Card",
                    "slug": "card"
                },
                {
                    "color": "#e8eaed",
                    "name": "Muted",
                    "slug": "muted"
                },
                {
                    "color": "#5c6370",
                    "name": "Muted Foreground",
                    "slug": "muted-foreground"
                },
                {
                    "color": "#c53030",
                    "name": "Destructive",
                    "slug": "destructive"
                }
            ],
            "gradients": [
                {
                    "gradient": "linear-gradient(135deg, hsl(200 75% 30%) 0%, hsl(200 75% 40%) 100%)",
                    "name": "Hero",
                    "slug": "hero"
                },
                {
                    "gradient": "linear-gradient(135deg, hsl(24 90% 45%) 0%, hsl(38 92% 50%) 100%)",
                    "name": "Accent",
                    "slug": "accent"
                },
                {
                    "gradient": "linear-gradient(180deg, hsl(220 20% 12%) 0%, hsl(220 20% 18%) 100%)",
                    "name": "Dark",
                    "slug": "dark"
                }
            ]
        },
        "layout": {
            "contentSize": "900px",
            "wideSize": "1400px"
        },
        "spacing": {
            "padding": true,
            "margin": true,
            "blockGap": true,
            "units": ["px", "em", "rem", "%", "vh", "vw"]
        },
        "typography": {
            "customFontSize": true,
            "fluid": true,
            "fontFamilies": [
                {
                    "fontFamily": "'Inter', system-ui, -apple-system, sans-serif",
                    "name": "Inter",
                    "slug": "body"
                },
                {
                    "fontFamily": "'Outfit', system-ui, -apple-system, sans-serif",
                    "name": "Outfit",
                    "slug": "heading"
                },
                {
                    "fontFamily": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
                    "name": "Monospace",
                    "slug": "mono"
                }
            ],
            "fontSizes": [
                {
                    "fluid": {
                        "min": "0.75rem",
                        "max": "0.75rem"
                    },
                    "name": "Extra Small",
                    "size": "0.75rem",
                    "slug": "xs"
                },
                {
                    "fluid": {
                        "min": "0.875rem",
                        "max": "0.875rem"
                    },
                    "name": "Small",
                    "size": "0.875rem",
                    "slug": "sm"
                },
                {
                    "fluid": {
                        "min": "1rem",
                        "max": "1rem"
                    },
                    "name": "Base",
                    "size": "1rem",
                    "slug": "base"
                },
                {
                    "fluid": {
                        "min": "1.125rem",
                        "max": "1.25rem"
                    },
                    "name": "Large",
                    "size": "1.25rem",
                    "slug": "lg"
                },
                {
                    "fluid": {
                        "min": "1.25rem",
                        "max": "1.5rem"
                    },
                    "name": "Extra Large",
                    "size": "1.5rem",
                    "slug": "xl"
                },
                {
                    "fluid": {
                        "min": "1.5rem",
                        "max": "2.25rem"
                    },
                    "name": "2XL",
                    "size": "2.25rem",
                    "slug": "2xl"
                },
                {
                    "fluid": {
                        "min": "1.875rem",
                        "max": "3rem"
                    },
                    "name": "3XL",
                    "size": "3rem",
                    "slug": "3xl"
                },
                {
                    "fluid": {
                        "min": "2.25rem",
                        "max": "3.75rem"
                    },
                    "name": "4XL",
                    "size": "3.75rem",
                    "slug": "4xl"
                }
            ]
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "custom": {
            "spacing": {
                "small": "1rem",
                "medium": "2rem",
                "large": "4rem",
                "xlarge": "6rem"
            }
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--background)",
            "text": "var(--wp--preset--color--foreground)"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--body)",
            "fontSize": "var(--wp--preset--font-size--base)",
            "lineHeight": "1.6"
        },
        "elements": {
            "button": {
                "border": {
                    "radius": "0.5rem"
                },
                "color": {
                    "background": "var(--wp--preset--color--primary)",
                    "text": "var(--wp--preset--color--primary-foreground)"
                },
                "typography": {
                    "fontWeight": "500"
                }
            },
            "heading": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--heading)",
                    "fontWeight": "700"
                }
            },
            "link": {
                "color": {
                    "text": "var(--wp--preset--color--primary)"
                },
                ":hover": {
                    "color": {
                        "text": "var(--wp--preset--color--accent)"
                    }
                }
            }
        },
        "blocks": {
            "core/button": {
                "border": {
                    "radius": "0.5rem"
                }
            },
            "core/group": {
                "spacing": {
                    "padding": {
                        "top": "0",
                        "right": "0",
                        "bottom": "0",
                        "left": "0"
                    }
                }
            }
        }
    },
    "templateParts": [
        {
            "name": "header",
            "title": "Header",
            "area": "header"
        },
        {
            "name": "footer",
            "title": "Footer",
            "area": "footer"
        }
    ],
    "customTemplates": [
        {
            "name": "blank",
            "title": "Blank",
            "postTypes": ["page"]
        }
    ]
}
